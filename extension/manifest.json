{
  "manifest_version": 3,
  "name": "Trustellix",
  "version": "1.0.0",
  "description": "AI-powered job scam protection for Nigerian graduates.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.jobberman.com/*",
    "https://*.indeed.com/*",
    "https://*.myjobmag.com/*",
    "https://*.ngcareers.com/*",
    "https://*.hotnigerianjobs.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/*",
        "https://*.jobberman.com/*",
        "https://*.indeed.com/*",
        "https://*.myjobmag.com/*",
        "https://*.ngcareers.com/*",
        "https://*.hotnigerianjobs.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Trustellix"
  }
}